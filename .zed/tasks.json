// Remote Tasks Configuration
// These tasks run on the remote server
[
    // C++ tasks (pixi経由)
    {
        "label": "cmake config (Release)",
        "command": "pixi",
        "args": ["run", "config"],
        "tags": ["build"],
    },
    {
        "label": "cmake config (Debug)",
        "command": "pixi",
        "args": ["run", "config-debug"],
        "tags": ["build"],
    },
    {
        "label": "cmake build",
        "command": "pixi",
        "args": ["run", "build"],
        "tags": ["build"],
    },
    {
        "label": "cmake clean",
        "command": "pixi",
        "args": ["run", "clean"],
        "tags": ["build"],
    },
    {
        "label": "ctest",
        "command": "pixi",
        "args": ["run", "test"],
        "tags": ["test"],
    },
    {
        "label": "clang-format",
        "command": "pixi",
        "args": ["run", "format"],
        "tags": ["format"],
    },
    {
        "label": "clang-tidy",
        "command": "pixi",
        "args": ["run", "lint"],
        "tags": ["lint"],
    },
    {
        "label": "fullcheck (C++)",
        "command": "pixi",
        "args": ["run", "fullcheck"],
        "tags": ["lint"],
    },
    // Python tasks (uv経由)
    {
        "label": "pytest",
        "command": "uv",
        "args": ["run", "--frozen", "pytest", "--cov=src", "--cov-report=term"],
        "tags": ["test"],
    },
    {
        "label": "ruff format",
        "command": "uv",
        "args": ["run", "--frozen", "ruff", "format"],
        "tags": ["format"],
    },
    {
        "label": "ruff check",
        "command": "uv",
        "args": ["run", "--frozen", "ruff", "check", "--fix", "--show-fixes"],
        "tags": ["lint"],
    },
    {
        "label": "pyright",
        "command": "uv",
        "args": ["run", "--frozen", "pyright"],
        "tags": ["lint"],
    },
    // wheel生成
    {
        "label": "build wheel",
        "command": "./scripts/build_wheels.sh",
        "tags": ["build"],
    },
]
